# Copia este fichero a .env y rellena con tus credenciales reales.
# NUNCA subas el .env al repositorio.

# Google Places API Key
# Obtenla en: https://console.cloud.google.com/apis/credentials
# Activa: Places API (New), Geocoding API, Maps JavaScript API
GOOGLE_PLACES_API_KEY=tu_api_key_aqui

# Ollama (IA local). Por defecto corre en localhost:11434
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# Región por defecto para búsquedas (bias de resultados)
DEFAULT_REGION=Tenerife, España
DEFAULT_LANGUAGE=es
